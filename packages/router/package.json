{
    "name": "@sigx/router",
    "version": "0.6.1",
    "description": "Router for SignalX with SSR support and hooks",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "vite build && tsgo --emitDeclarationOnly",
        "dev": "vite build --watch"
    },
    "keywords": [
        "sigx",
        "router",
        "routing",
        "navigation",
        "ssr"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/router.git",
        "directory": "packages/router"
    },
    "homepage": "https://sigx.dev/router/",
    "bugs": {
        "url": "https://github.com/signalxjs/router/issues"
    },
    "peerDependencies": {
        "@sigx/reactivity": ">=0.6.0 <0.7.0",
        "@sigx/runtime-core": ">=0.6.0 <0.7.0",
        "@sigx/runtime-dom": ">=0.6.0 <0.7.0",
        "sigx": ">=0.6.0 <0.7.0"
    },
    "devDependencies": {
        "@sigx/reactivity": "^0.6.1",
        "@sigx/runtime-core": "^0.6.1",
        "@sigx/runtime-dom": "^0.6.1",
        "@sigx/vite": "^0.6.1",
        "@types/node": "^20.0.0",
        "sigx": "^0.6.1",
        "typescript": "^6.0.3",
        "vite": "^8.0.16"
    },
    "publishConfig": {
        "access": "public"
    }
}
